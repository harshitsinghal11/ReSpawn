<UserControl x:Class="ReSpawn.Controls.GameTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReSpawn.Helpers"
             Width="175" Height="230" Cursor="Hand">

	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
		<helpers:StringToImageSourceConverter x:Key="ImageConverter"/>
	</UserControl.Resources>

	<Border Background="#13132b"
        CornerRadius="12"
        Margin="8"
        BorderBrush="#1e1e3a"
        BorderThickness="1"
        MouseLeftButtonDown="Border_MouseLeftButtonDown"
        Opacity="0">
		<Border.Triggers>
			<EventTrigger RoutedEvent="Loaded">
				<BeginStoryboard>
					<Storyboard>
						<DoubleAnimation Storyboard.TargetProperty="Opacity"
										 From="0" To="1"
										 Duration="0:0:0.3"
										 EasingFunction="{x:Null}"/>
						<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
										 From="12" To="0"
										 Duration="0:0:0.3">
							<DoubleAnimation.EasingFunction>
								<CubicEase EasingMode="EaseOut"/>
							</DoubleAnimation.EasingFunction>
						</DoubleAnimation>
					</Storyboard>
				</BeginStoryboard>
			</EventTrigger>
		</Border.Triggers>
		<Border.RenderTransform>
			<TranslateTransform Y="12"/>
		</Border.RenderTransform>

		<Border.Style>
			<Style TargetType="Border">
				<Style.Triggers>
					<Trigger Property="IsMouseOver" Value="True">
						<Setter Property="BorderBrush" Value="#e94560"/>
					</Trigger>
				</Style.Triggers>
			</Style>
		</Border.Style>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="145"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Icon Area -->
			<Border Grid.Row="0"
					Background="#0a1628"
					CornerRadius="12,12,0,0"
					ClipToBounds="True">
				<Grid>
					<!-- Game Icon -->
					<Image Source="{Binding IconPath,
               Converter={StaticResource ImageConverter}}"
						   Stretch="Uniform"
						   Margin="24"
						   RenderOptions.BitmapScalingMode="HighQuality"/>

					<!-- Status Dot top-right -->
					<Ellipse Width="9" Height="9"
							 HorizontalAlignment="Right"
							 VerticalAlignment="Top"
							 Margin="0,10,10,0">
						<Ellipse.Style>
							<Style TargetType="Ellipse">
								<Setter Property="Visibility" Value="Collapsed"/>
								<Setter Property="Fill" Value="Transparent"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding BadgeVisible}" Value="True">
										<Setter Property="Visibility" Value="Visible"/>
										<Setter Property="Fill" Value="#1db954"/>
										<Setter Property="ToolTip" Value="Now Playing"/>
									</DataTrigger>
									<DataTrigger Binding="{Binding IsPathBroken}" Value="True">
										<Setter Property="Visibility" Value="Visible"/>
										<Setter Property="Fill" Value="#e94560"/>
										<Setter Property="ToolTip" Value="File Not Found"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Ellipse.Style>
					</Ellipse>

					<!-- Hover Play Overlay -->
					<Border CornerRadius="12,12,0,0"
							Background="#AA000000"
							IsHitTestVisible="True">
						<Border.Style>
							<Style TargetType="Border">
								<Setter Property="Opacity" Value="0"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsMouseOver,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"
										Value="True">
										<DataTrigger.EnterActions>
											<BeginStoryboard>
												<Storyboard>
													<DoubleAnimation
														Storyboard.TargetProperty="Opacity"
														To="1" Duration="0:0:0.15"/>
												</Storyboard>
											</BeginStoryboard>
										</DataTrigger.EnterActions>
										<DataTrigger.ExitActions>
											<BeginStoryboard>
												<Storyboard>
													<DoubleAnimation
														Storyboard.TargetProperty="Opacity"
														To="0" Duration="0:0:0.15"/>
												</Storyboard>
											</BeginStoryboard>
										</DataTrigger.ExitActions>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Border.Style>

						<!-- Play Button -->
						<Button HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Command="{Binding LaunchCommand,
                        RelativeSource={RelativeSource AncestorType=UserControl}}"
								CommandParameter="{Binding DataContext,
                        RelativeSource={RelativeSource AncestorType=UserControl}}"
								Cursor="Hand"
								BorderThickness="0"
								Background="Transparent">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="playBtn"
											Background="#e94560"
											CornerRadius="50"
											Width="46" Height="46">
										<TextBlock Text="▶"
												   Foreground="White"
												   FontSize="16"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center"
												   Margin="4,0,0,0"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="playBtn"
													Property="Background"
													Value="#c73652"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</Border>
				</Grid>
			</Border>

			<!-- Info Area -->
			<Border Grid.Row="1"
                    Background="#0f0f26"
                    CornerRadius="0,0,12,12"
                    Padding="12,10">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="6"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Game Name -->
					<TextBlock Grid.Row="0"
           Text="{Binding Name}"
           Foreground="#f0f0ff"
           FontSize="13"
           FontWeight="SemiBold"
           TextTrimming="CharacterEllipsis">

						<TextBlock.ToolTip>
							<ToolTip Background="#1e1e3e"
									 Foreground="White"
									 BorderBrush="#e94560"
									 BorderThickness="1"
									 Padding="10,6"
									 FontSize="12">
								<TextBlock Text="{Binding Name}"
										   TextWrapping="Wrap"/>
							</ToolTip>
						</TextBlock.ToolTip>

					</TextBlock>
								
					<!-- Thin accent line -->
					<Rectangle Grid.Row="1"
                               Height="1"
                               Fill="#1e1e3a"
                               Margin="0,4,0,0"/>

					<!-- Playtime + Status Row -->
					<Grid Grid.Row="2" Margin="0,2,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<!-- Playtime -->
						<StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
							<TextBlock Text="⏱ "
                                       Foreground="#444466"
                                       FontSize="10"/>
							<TextBlock Text="{Binding FormattedPlaytime}"
                                       Foreground="#6666aa"
                                       FontSize="11"/>
						</StackPanel>

						<!-- Last Played -->
						<TextBlock Grid.Column="1"
                                   Text="{Binding StatusText}"
                                   Foreground="#333355"
                                   FontSize="10"
                                   VerticalAlignment="Center">
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Visibility" Value="Visible"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding BadgeVisible}"
                                                     Value="True">
											<Setter Property="Visibility" Value="Collapsed"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
					</Grid>
				</Grid>
			</Border>
		</Grid>
	</Border>
</UserControl>