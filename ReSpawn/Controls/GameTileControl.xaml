<UserControl x:Class="ReSpawn.Controls.GameTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReSpawn.Helpers"
             Width="175" Height="230" Cursor="Hand">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:StringToImageSourceConverter x:Key="ImageConverter"/>
    </UserControl.Resources>

    <Border Background="#13132b"
            CornerRadius="10"
            Margin="8"
            BorderBrush="#252545"
            BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#e94560"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#e94560"
                                                 BlurRadius="14"
                                                 Opacity="0.3"
                                                 ShadowDepth="0"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="145"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Icon Area -->
            <Border Grid.Row="0"
                    Background="#0c1830"
                    CornerRadius="10,10,0,0"
                    ClipToBounds="True">
                <Grid>
                    <Image Source="{Binding IconPath, 
                           Converter={StaticResource ImageConverter}}"
                           Stretch="Uniform"
                           Margin="22"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Status Dot — top right -->
                    <Ellipse Width="10" Height="10"
         HorizontalAlignment="Right"
         VerticalAlignment="Top"
         Margin="0,8,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Fill" Value="Transparent"/>
                                <Style.Triggers>
                                    <!-- Green = Now Playing -->
                                    <DataTrigger Binding="{Binding BadgeVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Fill" Value="#1db954"/>
                                        <Setter Property="ToolTip" Value="Now Playing"/>
                                    </DataTrigger>
                                    <!-- Red = File Not Found -->
                                    <DataTrigger Binding="{Binding IsPathBroken}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Fill" Value="#e94560"/>
                                        <Setter Property="ToolTip" Value="File Not Found — please re-link the executable"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>
            </Border>

            <!-- Info Area -->
            <Border Grid.Row="1"
                    Background="#16162e"
                    CornerRadius="0,0,10,10"
                    Padding="12,8">
                <StackPanel>

                    <!-- Game Name -->
                    <TextBlock Text="{Binding Name}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,5"/>

                    <!-- Divider -->
                    <Rectangle Height="1"
                               Fill="#252545"
                               Margin="0,0,0,6"/>

                    <!-- Playtime + Last Played Row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding FormattedPlaytime}"
                                   Foreground="#7777aa"
                                   FontSize="11"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusText}"
                                   Foreground="#444466"
                                   FontSize="10"
                                   HorizontalAlignment="Right">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BadgeVisible}" 
                                                     Value="True">
                                            <Setter Property="Visibility" 
                                                    Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>