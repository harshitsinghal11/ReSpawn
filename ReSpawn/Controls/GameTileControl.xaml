<UserControl x:Class="ReSpawn.Controls.GameTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ReSpawn.Helpers"
             Width="175" Height="230" Cursor="Hand">

	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
		<helpers:StringToImageSourceConverter x:Key="ImageConverter"/>
	</UserControl.Resources>

	<Border Background="#13132b"
            CornerRadius="12"
            Margin="8"
            BorderBrush="#1e1e3a"
            BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

		<Border.Style>
			<Style TargetType="Border">
				<Style.Triggers>
					<Trigger Property="IsMouseOver" Value="True">
						<Setter Property="BorderBrush" Value="#e94560"/>
					</Trigger>
				</Style.Triggers>
			</Style>
		</Border.Style>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="145"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Icon Area -->
			<Border Grid.Row="0"
                    Background="#0a1628"
                    CornerRadius="12,12,0,0"
                    ClipToBounds="True">
				<Grid>
					<Image Source="{Binding IconPath,
                           Converter={StaticResource ImageConverter}}"
                           Stretch="Uniform"
                           Margin="24"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

					<!-- Status Dot top-right -->
					<Ellipse Width="9" Height="9"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,10,10,0">
						<Ellipse.Style>
							<Style TargetType="Ellipse">
								<Setter Property="Visibility" Value="Collapsed"/>
								<Setter Property="Fill" Value="Transparent"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding BadgeVisible}" Value="True">
										<Setter Property="Visibility" Value="Visible"/>
										<Setter Property="Fill" Value="#1db954"/>
										<Setter Property="ToolTip" Value="Now Playing"/>
									</DataTrigger>
									<DataTrigger Binding="{Binding IsPathBroken}" Value="True">
										<Setter Property="Visibility" Value="Visible"/>
										<Setter Property="Fill" Value="#e94560"/>
										<Setter Property="ToolTip" Value="File Not Found"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Ellipse.Style>
					</Ellipse>
				</Grid>
			</Border>

			<!-- Info Area -->
			<Border Grid.Row="1"
                    Background="#0f0f26"
                    CornerRadius="0,0,12,12"
                    Padding="12,10">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="6"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Game Name -->
					<TextBlock Grid.Row="0"
                               Text="{Binding Name}"
                               Foreground="#f0f0ff"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>

					<!-- Thin accent line -->
					<Rectangle Grid.Row="1"
                               Height="1"
                               Fill="#1e1e3a"
                               Margin="0,4,0,0"/>

					<!-- Playtime + Status Row -->
					<Grid Grid.Row="2" Margin="0,2,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<!-- Playtime -->
						<StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
							<TextBlock Text="⏱ "
                                       Foreground="#444466"
                                       FontSize="10"/>
							<TextBlock Text="{Binding FormattedPlaytime}"
                                       Foreground="#6666aa"
                                       FontSize="11"/>
						</StackPanel>

						<!-- Last Played -->
						<TextBlock Grid.Column="1"
                                   Text="{Binding StatusText}"
                                   Foreground="#333355"
                                   FontSize="10"
                                   VerticalAlignment="Center">
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Visibility" Value="Visible"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding BadgeVisible}"
                                                     Value="True">
											<Setter Property="Visibility" Value="Collapsed"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
					</Grid>
				</Grid>
			</Border>
		</Grid>
	</Border>
</UserControl>