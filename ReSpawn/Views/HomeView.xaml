<UserControl x:Class="ReSpawn.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ReSpawn.Controls"
             Background="#1a1a2e"
             AllowDrop="True"
             Drop="Grid_Drop">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#0e0e1f"
                BorderBrush="#1e1e3a"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Title + Count -->
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                    <TextBlock Text="My Library"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding LibraryStatusText}"
                               Foreground="#555577"
                               FontSize="11"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Center: Search -->
                <Border Grid.Column="1"
                        Background="#12122a"
                        BorderBrush="#2a2a4a"
                        BorderThickness="1"
                        CornerRadius="6"
                        VerticalAlignment="Center"
                        MaxWidth="520"
                        HorizontalAlignment="Stretch">
                    <Grid>
                        <TextBlock Text="Search Library..."
                                   Foreground="#444466"
                                   FontSize="13"
                                   Padding="12,8"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="12,8"
                                 FontSize="13"
                                 CaretBrush="White"
                                 SelectionBrush="#e94560"/>
                    </Grid>
                </Border>

                <!-- Right: Buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">

                    <!-- Add Game -->
                    <Button Command="{Binding AddGameCommand}"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            Background="#e94560"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg"
                                        Background="#e94560"
                                        CornerRadius="6"
                                        Padding="16,8">
                                    <TextBlock Text="+ Add Game"
                                               Foreground="White"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#c73652"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Power Button -->
                    <Button Command="{Binding ShutdownCommand}"
                            ToolTip="Exit Completely"
                            Cursor="Hand"
                            BorderThickness="0"
                            Background="Transparent">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg"
                                        Background="#1a1a2e"
                                        CornerRadius="6"
                                        Width="36" Height="36">
                                    <TextBlock x:Name="icon"
                                               Text="⏻"
                                               FontSize="16"
                                               Foreground="#444466"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#2a1020"/>
                                        <Setter TargetName="icon" Property="Foreground" Value="#e94560"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Game Grid -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="🎮"
                               FontSize="64"
                               HorizontalAlignment="Center"
                               Foreground="White"/>
                    <TextBlock Text="Your library is empty"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,6"/>
                    <TextBlock Text="Add a game or drop an .exe file anywhere on this screen"
                               Foreground="#555577"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>
                   
                </StackPanel>

                <!-- Tiles -->
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="16"
                                       Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:GameTileControl
                                DataContext="{Binding}"
                                LaunchCommand="{Binding DataContext.LaunchGameCommand,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Tag="{Binding DataContext,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <controls:GameTileControl.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🚀 Launch"
                                                  Command="{Binding PlacementTarget.Tag.LaunchGameCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="✏️ Edit"
                                                  Command="{Binding PlacementTarget.Tag.EditGameCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="🗑️ Remove"
                                                  Command="{Binding PlacementTarget.Tag.RemoveGameCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </controls:GameTileControl.ContextMenu>
                            </controls:GameTileControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>